package service;

import java.util.List;


import java.util.Optional;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import com.mandeep.reservation_service.GuestClient;

import entity.GuestDTO;
import entity.Reservation;
import entity.Room;
import repo.ReservationRepository;
import repo.RoomRepository;

@Service
public class ReservationService {
	
	@Autowired
    private ReservationRepository repository;
	
	@Autowired
	private RoomRepository roomRepository;
	
//	@Autowired
//	private GuestClient guestClient;
    
	
    public List<Reservation> getAllReservations() { 
    	return repository.findAll(); }
    
    public Optional<Reservation> getReservationById(Long id) { 
    	return repository.findById(id);}
    
    
    
    public  Reservation createReservation(Reservation reservation, String username) { 
    	Room room = roomRepository.findByRoomNumber(reservation.getRoomNumber()); 
    	
    	 if (room != null) {
    	        // Set reservation details
    	        reservation.setRoomType(room.getRoomType());

    	        // Save reservation in repository
    	        Reservation savedReservation = repository.save(reservation);

    	        // Remove booked room from inventory
    	        roomRepository.delete(room);

    	        return savedReservation;
    	    } 
    	 else 
    	 {      throw new RuntimeException("Room not available for booking.");
    	    }
    	}
    
    
    public void deleteReservation(Long id) { 
    	repository.deleteById(id); }
    
//    public GuestDTO getGuestDetails(Long guestId) {
//        return guestClient.getGuestById(guestId); }

	public Room addRoomToInventory(String roomNumber, String roomType) {
		Room room = new Room(roomNumber, roomType, true);
		return roomRepository.save(room);
	}

	public List<Room> getAvailableRooms() {
		return roomRepository.findAll();
	}
	
	

}
